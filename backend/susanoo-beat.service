[Unit]
Description=Susanoo Celery Beat Scheduler
After=network.target redis6.service susanoo-worker.service

[Service]
User=ec2-user
WorkingDirectory=/home/ec2-user/susanoo/backend
Environment="PATH=/home/ec2-user/susanoo/backend/venv/bin"
ExecStart=/home/ec2-user/susanoo/backend/venv/bin/celery -A app.workers.celery_app beat --loglevel=info
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
